{
  "name": "depl0y-frontend",
  "version": "2.2.10",
  "description": "Depl0y Frontend - Vue.js deployment panel",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "deploy": "vite build && sudo rsync -a --delete dist/ /opt/depl0y/frontend/dist/ && sudo chown -R www-data:www-data /opt/depl0y/frontend/dist/",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "chart.js": "^4.4.0",
    "leaflet": "^1.9.4",
    "marked": "^17.0.0",
    "pinia": "^2.1.7",
    "qrcode.vue": "^3.4.1",
    "vue": "^3.3.8",
    "vue-chartjs": "^5.2.0",
    "vue-router": "^4.2.5",
    "vue-toastification": "^2.0.0-rc.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.5.0",
    "eslint": "^8.54.0",
    "eslint-plugin-vue": "^9.18.1",
    "vite": "^5.0.2"
  }
}
